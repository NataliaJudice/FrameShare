@{
    Layout = null; // Geralmente telas de login não usam a sidebar do layout principal
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - FrameShare</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
        --primary: #ec4899;
        --secondary: #8b5cf6;
        }

        body {
        background: linear-gradient(135deg, #fdf2f8 0%, #f5f3ff 100%);
        font-family: 'Outfit', sans-serif;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0;
        }

        .login-card {
        background: rgba(255, 255, 255, 0.7);
        backdrop-filter: blur(15px);
        border: 1px solid white;
        border-radius: 30px;
        padding: 40px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.05);
        width: 100%;
        max-width: 400px;
        text-align: center;
        }

        .brand-logo {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        margin: 0 auto 20px;
        }

        .login-title {
        font-weight: 800;
        font-size: 1.8rem;
        background: linear-gradient(to right, var(--primary), var(--secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 10px;
        }

        .form-control-custom {
        background: rgba(255, 255, 255, 0.9);
        border: 2px solid transparent;
        border-radius: 15px;
        padding: 12px 20px;
        font-weight: 600;
        text-align: center;
        transition: 0.3s;
        color: #1e293b;
        }

        .form-control-custom:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(236, 72, 153, 0.1);
        }

        .btn-login {
        background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
        color: white;
        border: none;
        border-radius: 15px;
        padding: 12px;
        width: 100%;
        font-weight: 700;
        margin-top: 20px;
        transition: 0.3s;
        }

        .btn-login:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(236, 72, 153, 0.3);
        }

        .hint {
        font-size: 0.85rem;
        color: #64748b;
        margin-top: 15px;
        }
    </style>
</head>
<body>

    <div class="login-card">
        <div class="brand-logo">
            <i data-lucide="camera" size="32"></i>
        </div>
        <h2 class="login-title">Bem-vindo(a)</h2>
        <p class="text-muted">Acesse o Mural de Memórias</p>

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 small py-2" style="border-radius: 10px;">
                @TempData["Error"]
            </div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post">
            <div class="mb-3">
                <input type="text"
                       name="loginDigitado"
                       class="form-control form-control-custom"
                       placeholder="Ex: natalianovais"
                       required
                       autocomplete="off">
            </div>
            
            <button type="submit" class="btn-login">Acessar Evento</button>
        </form>

        <p class="hint">
            <i data-lucide="info" size="14" style="vertical-align: middle"></i>
            Digite seu primeiro e último nome juntos (sem espaços).
        </p>
    </div>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>