@model FrameShare.WebUI.ViewModels.IndexViewModel
@{
    ViewData["Title"] = "Mural de Memórias";
}

<!-- IMPORTAÇÃO DE FONTES E DEPENDÊNCIAS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/lucide@latest"></script>
<style>
    :root {
    --primary: #ec4899;
    --secondary: #8b5cf6;
    --accent: #f472b6;
    --bg-main: #f8fafc;
    --card-shadow: 0 10px 30px -5px rgba(236, 72, 153, 0.1), 0 8px 15px -6px rgba(0, 0, 0, 0.05);
    --text-dark: #0f172a;
    --text-muted: #64748b;
    }

    body {
    background: linear-gradient(135deg, #fdf2f8 0%, #f5f3ff 100%);
    min-height: 100vh;
    font-family: 'Outfit', sans-serif;
    }

    .container-custom {
    max-width: 1200px;
    margin: 0 auto;
    padding: 15px;
    }

    /* HEADER */
    .welcome-header h4 {
    font-weight: 800;
    font-size: 2.5rem;
    background: linear-gradient(135deg, #ec4899 0%, #8b5cf6 50%, #6366f1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -2px;
    filter: drop-shadow(0 2px 10px rgba(236, 72, 153, 0.2));
    }

    /* CARDS */
    .glass-card {
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(10px);
    border-radius: 28px;
    padding: 24px;
    box-shadow: var(--card-shadow);
    border: 1px solid white;
    margin-bottom: 24px;
    }

    .card-title {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text-dark);
    }

    .card-title i {
    color: var(--primary);
    }

    /* UPLOAD ZONE */
    .upload-zone {
    border: 3px dashed #f0abfc;
    border-radius: 24px;
    padding: 35px 20px;
    text-align: center;
    transition: all 0.3s ease;
    background: #fff9fc;
    cursor: pointer;
    }

    /* MISSÕES */
    .mission-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    }

    .mission-card {
    background: white;
    border-radius: 24px;
    padding: 20px;
    border: 1px solid rgba(139, 92, 246, 0.1);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    }

    .mission-icon {
    width: 45px;
    height: 45px;
    background: #f5f3ff;
    color: var(--secondary);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 15px;
    }

    .btn-mission-upload {
    background: #fdf2f8;
    color: var(--primary);
    border: 2px dashed var(--accent);
    width: 100%;
    padding: 10px;
    border-radius: 14px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    }

    /* GALLERY */
    .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 15px;
    }

    .photo-wrapper {
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 1/1;
    border: 4px solid white;
    box-shadow: 0 5px 15px rgba(0,0,0,0.08);
    }

    .photo-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    }

    /* BOTÕES */
    .btn-submit {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border: none;
    padding: 15px;
    border-radius: 15px;
    font-weight: 700;
    width: 100%;
    }

    .modal-content {
    border-radius: 28px;
    border: none;
    }
</style>

<div class="container-custom">
    <!-- HEADER -->
    <div class="topbar mb-4">
        <div class="welcome-header text-center text-md-start">
            <h4 class="mb-0">Olá, Natália!</h4>
            <div class="text-muted fw-500">Vamos eternizar um momento hoje?</div>
        </div>
    </div>

    <div class="row">
        <!-- UPLOAD LIVRE -->
        <div class="col-md-8">
            <div class="glass-card">
                <span class="card-title"><i data-lucide="sparkles"></i> Nova Memória</span>
                <form asp-action="Index" method="post" enctype="multipart/form-data">
                    <div class="upload-zone" id="dropzone" onclick="document.getElementById('fileInput').click()">
                        <div class="upload-icon-circle" style="width: 50px; height: 50px; background: linear-gradient(135deg, var(--primary), var(--secondary)); border-radius: 15px; display: flex; align-items: center; justify-content: center; margin: 0 auto 10px; color: white;">
                            <i data-lucide="plus"></i>
                        </div>
                        <p class="fw-bold mb-0">Toque para postar foto livre</p>
                    </div>
                    <input type="file" name="file" id="fileInput" class="d-none" accept="image/*" />

                    <div id="previewContainer" class="mt-3 text-center" style="display: none;">
                        <img id="imagePreview" src="#" style="max-height: 200px; border-radius: 15px;" class="mb-3 shadow-sm" />
                        <button type="submit" class="btn-submit">Postar no Mural</button>
                    </div>
                </form>
            </div>
        </div>

        <!-- STATUS -->
        <div class="col-md-4 mb-4">
            <div class="glass-card h-100">
                <span class="card-title"><i data-lucide="bar-chart-3"></i> O Evento</span>
                <div class="d-flex justify-content-between py-2 border-bottom">
                    <span class="text-muted font-small">Missoes concluídas</span>
                    <span class="fw-bold">@Model?.Fotos.Count()</span>
                </div>
                <div class="d-flex justify-content-between py-2">
                    <span class="text-muted font-small">Status</span>
                    <span class="badge bg-success rounded-pill">Online</span>
                </div>
            </div>
        </div>
    </div>

    <!-- SEÇÃO DE MISSÕES -->
    <div class="glass-card">
        <span class="card-title"><i data-lucide="trophy"></i> Missões Fotográficas</span>
        <div class="mission-grid">
            @if (Model.Missao != null)
            {
                @foreach (var missao in Model.Missao)
                {
                    <div class="mission-card shadow-sm">
                        <div>
                            <div class="mission-icon"><i data-lucide="@missao.Icone"></i></div>
                            <div class="mission-title fw-bold">@missao.Titulo</div>
                            <p class="text-muted small">@missao.Descricao</p>
                        </div>
                        <button class="btn-mission-upload mt-3" onclick="triggerMissionUpload('@missao.Id', '@missao.Titulo')">
                            <i data-lucide="camera" size="18"></i> Cumprir Missão
                        </button>
                    </div>
                }
            }
        </div>
    </div>

    <!-- MURAL -->
    <div class="glass-card">
        <span class="card-title"><i data-lucide="layers"></i> Mural Recente</span>
        <div class="gallery-grid">
            @foreach (var foto in Model.Fotos)
            {
                <div class="photo-wrapper">
                    <img src="@foto.UrlDrive" loading="lazy" />
                </div>
            }
        </div>
    </div>
</div>

<!-- MODAL DE CONFIRMAÇÃO -->
<div class="modal fade" id="confirmMissionModal" tabindex="-1" aria-labelledby="modalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-body text-center p-4">
                <h5 class="fw-bold mb-3" id="modalTitle">Eternizar Missão?</h5>
                <p class="text-muted small mb-3" id="modalMissionText"></p>
                <div class="bg-light rounded-4 p-2 mb-4">
                    <img id="modalImagePreview" src="" class="img-fluid rounded-4" style="max-height: 250px; width: 100%; object-fit: cover;">
                </div>
                
                <div class="d-grid gap-2">
                    <button type="button" class="btn-submit" onclick="sendMissionPhoto()">Sim, enviar agora!</button>
                    <button type="button" class="btn btn-link text-muted text-decoration-none" data-bs-dismiss="modal">Cancelar</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FORMS OCULTOS -->
<form id="missionForm" asp-action="UploadPorMissao" method="post" enctype="multipart/form-data" class="d-none">
    <input type="file" name="file" id="missionFileInput" accept="image/*">
    <input type="hidden" name="idMissao" id="missionIdInput">
</form>

<script>
    // Inicializar ícones
   

    document.addEventListener("DOMContentLoaded", function() {
    lucide.createIcons();
    let selectedId = null;
    const missionFileInput = document.getElementById('missionFileInput');
    const modalElement = document.getElementById('confirmMissionModal');
        
    // Inicialização segura da Modal
    const missionModal = new bootstrap.Modal(modalElement);

    // Função disparada pelo botão do card
    window.triggerMissionUpload = function(id, desc) {
    selectedId = id;
    document.getElementById('modalMissionText').innerText = desc;
    missionFileInput.click();
    };

    // Quando o arquivo é selecionado
    missionFileInput.onchange = function() {
    if (this.files && this.files[0]) {
    const reader = new FileReader();
    reader.onload = (e) => {
    document.getElementById('modalImagePreview').src = e.target.result;
    missionModal.show(); // Abre a modal
    };
    reader.readAsDataURL(this.files[0]);
    }
    };

    // Enviar formulário
    window.sendMissionPhoto = function() {
    if (!selectedId) return;
            
    document.getElementById('missionIdInput').value = selectedId;
    const btn = document.querySelector('#confirmMissionModal .btn-submit');
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Enviando...';
    btn.disabled = true;
            
    document.getElementById('missionForm').submit();
    };

    // Lógica Preview Upload Principal
    const fileInput = document.getElementById('fileInput');
    fileInput.onchange = function() {
    if (this.files && this.files[0]) {
    const reader = new FileReader();
    reader.onload = (e) => {
    document.getElementById('imagePreview').src = e.target.result;
    document.getElementById('previewContainer').style.display = 'block';
    document.getElementById('dropzone').style.display = 'none';
    };
    reader.readAsDataURL(this.files[0]);
    }
    };
    });

  
</script>